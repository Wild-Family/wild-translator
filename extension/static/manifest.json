{
  "manifest_version": 3,
  "name": "Wild Translator",
  "version": "0.1.0",
  "description": "AI translator popup with customizable prompts",
  "action": {
    "default_title": "Wild Translator",
    "default_popup": "ui/popup/index.html"
  },
  "options_page": "ui/options/index.html",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "commands": {
    "open_ui": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open Wild Translator UI"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
