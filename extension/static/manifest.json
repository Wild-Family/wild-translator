{
  "manifest_version": 3,
  "name": "わいるどぱんち",
  "version": "0.1.2",
  "description": "AI translator popup with customizable prompts",
  "action": {
    "default_title": "わいるどぱんち",
    "default_popup": "ui/popup/index.html"
  },
  "options_page": "ui/options/index.html",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "extension/src/background.js",
    "type": "module"
  },
  "commands": {
    "open_ui": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open わいるどぱんち UI"
    }
  }
}
